# FANCLUV — Supabase 연결 환경변수
# 이 파일을 복사해 `.env` 로 만들고 실제 값으로 채우세요. (.env 는 git에 커밋되지 않음)
#
#   cp .env.example .env
#
# 값은 Supabase 대시보드 → Project Settings → API 에서 확인:
#   - Project URL          → VITE_SUPABASE_URL
#   - Project API keys / anon public → VITE_SUPABASE_ANON_KEY
#
# anon(public) key 는 클라이언트에 노출되어도 안전한 공개 키입니다.
# (service_role key 는 절대 프론트엔드/깃에 넣지 마세요.)
#
# ── 운영/개발 모드 (중요) ──
# VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY 가 설정되면 → 실제 Supabase 사용.
# 미설정이면 → localStorage Mock 모드(데모 데이터). 단 데모 계정(admin@fancluv.kr 등)은
#   **개발(dev) 빌드에서만** 시드됩니다. 운영(프로덕션) 빌드에서 미설정 시 데모 관리자
#   계정이 생기지 않고 콘솔에 설정 오류 경고가 출력됩니다.
# → 운영 배포에는 반드시 아래 Supabase 값을 설정하세요.
#
# ── 필요한 DB 마이그레이션 (Supabase SQL Editor 에서 순서대로 실행) ──
#   supabase/migrations/0001_profiles.sql                 프로필 + 인증
#   supabase/migrations/0003_nickname_and_find_account.sql 닉네임 쿨다운 + 아이디 찾기 RPC
#   supabase/migrations/0004_opinions_comments_likes.sql   팬 의견 / 댓글 / 공감
#   supabase/migrations/0005_surveys.sql                   설문 / 설문 응답 + is_admin()
#   supabase/migrations/0006_news_notifications.sql        팀 뉴스 / 알림 + 알림 트리거
#   supabase/migrations/0007_social_login.sql              소셜 로그인 프로필 매핑
#   supabase/migrations/0008_profiles_email_index.sql      profiles.email 인덱스(소셜 콜백 조회)
#   supabase/migrations/0009_ai_insights.sql               AI 팬 인사이트 결과 저장
#   supabase/migrations/0010_account_hardening.sql         회원탈퇴 + 이메일 인증번호
#   supabase/migrations/0011_reports_notices.sql           신고 / 공지 + 알림 트리거
#   supabase/migrations/0012_avatars_storage.sql           프로필 이미지 Storage(avatars 버킷)
#   supabase/migrations/0013_admin_dashboard_stats.sql     관리자 대시보드 집계 RPC
#   supabase/migrations/0014_admin_ops.sql                 공지 테이블 / 운영자 내부 메모
#   supabase/migrations/0015_notice_important.sql          공지 중요 플래그
#   supabase/migrations/0016_club_reports.sql              구단 전달용 리포트
#   supabase/migrations/0017_report_delivery.sql           리포트 전달 이력
#   supabase/migrations/0018_customers.sql                 B2B 고객 / 계약 이력
#   supabase/migrations/0019_news_cache.sql                팀 뉴스 캐시(news-fetcher Edge Function)
#   supabase/migrations/0020_league_cache.sql              리그 데이터 캐시(league-fetcher Edge Function)
#   supabase/migrations/0021_news_sources.sql              뉴스 소스 관리 + 수집 상태(AdminNewsSources)
#   supabase/migrations/0022_integration_health.sql        통합 상태 + 시스템 로그(AdminSystemStatus)
#   supabase/migrations/0023_club_kpi_history.sql          KPI 주차 히스토리(Fan Insight KPI Engine)
#   supabase/migrations/0024_club_actions.sql              구단 액션 + 전후 KPI 스냅샷(AdminClubActions)
#   supabase/migrations/0025_club_action_result.sql        구단 액션 운영자 메모(Club Action Tracker)
#   supabase/migrations/0026_identity_verification.sql      본인인증(CI/DI) + claim_identity RPC + insert 게이트
#   supabase/migrations/0027_roles_and_admin_members.sql    역할 enum 확장 + is_admin 보강 + 관리자 회원 조회/상태 RPC
#   (0002_data_tables.sql = DEPRECATED, 실행 불필요)

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── 소셜 로그인 (자세한 설정: SOCIAL_LOGIN_SETUP.md) ──
# Google · Kakao 는 Supabase 기본 지원 → Client ID/Secret 을 Supabase 대시보드
#   (Authentication → Providers) 에 입력합니다. 프론트 .env 에는 넣지 않습니다.
# NAVER 는 Supabase 미지원 → 커스텀 OAuth. Client ID(공개)는 아래에, Secret 은
#   Edge Function 시크릿으로 보관합니다(프론트 노출 금지).
VITE_NAVER_CLIENT_ID=your-naver-client-id
VITE_NAVER_CALLBACK_URL=https://your-project.supabase.co/functions/v1/naver-callback

# (참고) Google·Kakao provider 값은 Supabase 대시보드에 입력합니다(프론트 .env 아님).
# GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET   → Supabase Google provider
# KAKAO_REST_API_KEY / KAKAO_CLIENT_SECRET  → Supabase Kakao provider

# ── NAVER Edge Function 시크릿 (naver-callback) ──
# ⚠️ 프론트엔드/번들에 절대 포함하지 마세요. (VITE_ 접두사 없음 → Vite가 노출하지 않음)
#    `supabase secrets set KEY=VALUE ...` 로 설정합니다. 값은 비워둡니다.
#   NAVER_CLIENT_ID=            # NAVER 애플리케이션 Client ID
#   NAVER_CLIENT_SECRET=        # NAVER 애플리케이션 Client Secret (서버 전용)
#   NAVER_REDIRECT_URI=https://your-project.supabase.co/functions/v1/naver-callback
#   SUPABASE_URL=https://your-project.supabase.co   # (플랫폼 자동 주입, 로컬 실행 시 필요)
#   SUPABASE_SERVICE_ROLE_KEY=  # service_role 키 — Edge Function 에서만 사용 (절대 노출 금지)
#   SITE_URL=http://localhost:5173  # (선택) 로그인 후 복귀 앱 주소 폴백

# ── AI 인사이트 Edge Function 시크릿 (analyze-insights) ──
# ⚠️ OpenAI 키는 절대 프론트엔드/번들에 넣지 마세요. Edge Function 시크릿으로만 사용합니다.
#    `supabase secrets set OPENAI_API_KEY=sk-... OPENAI_MODEL=gpt-4o-mini`
#   OPENAI_API_KEY=             # OpenAI API 키 (서버 전용)
#   OPENAI_MODEL=gpt-4o-mini    # (선택) 사용 모델
#
# ※ VITE_OPENAI_MODEL 은 **의도적으로 사용하지 않습니다.** OpenAI 호출은 전적으로
#    analyze-insights Edge Function(서버)에서만 이루어지므로 모델명도 서버 시크릿
#    OPENAI_MODEL 로만 관리합니다. 프론트(VITE_)로 노출하면 불필요한 정보 노출이자
#    아키텍처상 무의미하므로 두지 않습니다.

# ── 이메일 Edge Function 시크릿 (send-email-code / send-welcome-email) ──
# ⚠️ 서버 전용(프론트 노출 금지). 없으면 각 함수가 dev/Mock fallback 으로 동작합니다.
#    `supabase secrets set RESEND_API_KEY=re_... EMAIL_FROM="FANCLUV <no-reply@fancluv.com>"`
#   RESEND_API_KEY=             # 이메일 발송용(Resend). 없으면 인증코드=devCode / 환영메일=미발송
#   EMAIL_FROM=                 # 발신자 (예: FANCLUV <no-reply@도메인>). 기본값 onboarding@resend.dev
#   두 함수 모두 --no-verify-jwt 로 배포:
#     supabase functions deploy send-email-code --no-verify-jwt
#     supabase functions deploy send-welcome-email --no-verify-jwt
#   회원가입 완료 시 send-welcome-email 이 가입 이메일로 환영 메일을 보냅니다.

# ── K리그 데이터 (League Provider) ──
# 순위/일정/결과 데이터 소스. 기본은 mock(데모). Provider 는 교체 가능한 구조:
#   - VITE_LEAGUE_PROVIDER=edge → Edge Function league-fetcher 사용 (★운영 권장: API 키 서버 보관)
#   - LEAGUE_PROVIDER=api        → 클라이언트 직접 API (공개/키없는 소스용. 비밀키는 edge 사용)
#   - LEAGUE_PROVIDER=mock       → Mock (기본값)
#   미지정 시: edge 가능하면 edge, VITE_LEAGUE_API_BASE 있으면 api, 없으면 mock.
# 어떤 벤더(API-Football/Sportmonks/Football-data/K리그 공식/자체 수집)든 응답을
# league-fetcher(또는 apiLeagueProvider)의 normalize* 만 맞추면 교체 가능(앱 코드 불변).
LEAGUE_PROVIDER=mock
VITE_LEAGUE_PROVIDER=mock   # mock | api | edge (edge = league-fetcher Edge Function)
VITE_LEAGUE_API_BASE=       # (api 모드) 예: https://api.example.com/kleague
VITE_LEAGUE_API_KEY=        # (api 모드, ⚠️ 번들 노출) 공개 키만. 비밀 키는 아래 edge 사용!
#
# ── league-fetcher Edge Function (edge 모드, API 키 서버 보관) ──
# ⚠️ 아래 값은 서버 전용(VITE_ 없음 → 프론트 미노출). Edge Function 시크릿으로만 설정.
#    `supabase secrets set LEAGUE_API_BASE=https://... LEAGUE_API_KEY=... [LEAGUE_API_VENDOR=...]`
#   LEAGUE_API_BASE=            # 외부 리그 API base URL (서버 전용)
#   LEAGUE_API_KEY=             # 외부 리그 API 비밀 키 (서버 전용 — 절대 프론트 금지)
#   LEAGUE_API_VENDOR=          # (선택) 벤더 식별자 — normalizer 분기용
# 배포:
#   1) 마이그레이션: supabase/migrations/0020_league_cache.sql (리그 캐시 테이블)
#   2) supabase functions deploy league-fetcher   (경기센터는 로그인 필요 → verify_jwt 기본 유지)
#   3) 프론트: VITE_LEAGUE_PROVIDER=edge 로 설정 (SUPABASE_URL/SERVICE_ROLE 는 자동 주입)

# ── 팀 뉴스 Provider (실제 뉴스 연동) ──
# 실제 구단 뉴스(RSS/공식 홈페이지)는 CORS 때문에 Supabase Edge Function `news-fetcher`가
# 서버에서 수집·정규화·10분 캐시한다. 클라이언트는 그 결과만 받아온다.
#   - VITE_NEWS_PROVIDER=edge → edgeNewsProvider 활성화(news-fetcher 호출) = 운영 권장
#   - 미설정/기타          → 실제 Provider 비활성 → 관리자 저장 뉴스(team_news) + Mock 폴백
# 배포:
#   1) 마이그레이션 실행: supabase/migrations/0019_news_cache.sql (뉴스 캐시 테이블)
#   2) supabase functions deploy news-fetcher   (팀 뉴스 페이지는 로그인 필요 → verify_jwt 기본 유지)
#      (SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY 는 플랫폼 자동 주입 — 별도 시크릿 없음)
#   3) 각 구단 실제 RSS/뉴스 경로는 src/lib/news/newsSources.js 의 SOURCE_OVERRIDES 에 반영.
VITE_NEWS_PROVIDER=         # 예: edge (news-fetcher 배포 후 켜기). 미설정 시 저장뉴스+Mock
NEWS_PROVIDER=edge          # (참고) 서버측 명시용. 실제 판단은 VITE_NEWS_PROVIDER 로 함.
VITE_NEWS_API_ENABLED=      # (레거시) newsApiProvider 용. edge 사용 시 불필요.

# ── 본인인증 (PASS / NICE / KCB — Identity Provider) ──
# 회원가입/소셜 최초가입 시 휴대폰 본인인증. Provider 는 교체 가능한 구조:
#   src/lib/identity/identityProvider.js → mock | pass | nice | kcb
#   - 미설정/mock → Mock 본인인증(개발/데모, 실제 인증창 없이 성공)
#   - pass | nice | kcb → 실 업체. Edge Function `identity-verify`(업체 비밀키 서버 보관)로 처리.
# 저장 정보(민감정보 없음): 인증 여부 · 인증 시각 · 인증 기관 · CI/DI. 동일 CI = 한 계정만.
VITE_IDENTITY_PROVIDER=mock  # mock | pass | nice | kcb  (운영은 실업체로 지정)
#
# ── identity-verify Edge Function 시크릿 (실업체 사용 시, ⚠️ 서버 전용·프론트 금지) ──
#    `supabase secrets set IDENTITY_VENDOR=nice IDENTITY_CLIENT_ID=... \
#       IDENTITY_CLIENT_SECRET=... IDENTITY_API_BASE=https://... IDENTITY_SITE_URL=https://your-app`
#   IDENTITY_VENDOR=            # pass | nice | kcb (사용 업체)
#   IDENTITY_CLIENT_ID=         # 업체 발급 Client ID (서버 전용)
#   IDENTITY_CLIENT_SECRET=     # 업체 발급 Client Secret (서버 전용 — 절대 프론트 금지)
#   IDENTITY_API_BASE=          # 업체 API base URL
#   IDENTITY_SITE_URL=          # 인증 콜백 복귀용 앱 주소 (예: https://fancluv.com)
# 배포(로그인 사용자만 호출 → verify_jwt 기본 유지):
#   1) 마이그레이션: supabase/migrations/0026_identity_verification.sql
#   2) supabase functions deploy identity-verify
#   3) 프론트: VITE_IDENTITY_PROVIDER=nice(또는 pass|kcb)
# ⚠️ CI/DI 발급·저장은 전적으로 Edge Function(서버)에서만 처리하며, 주민등록번호 등
#    민감정보는 저장하지 않습니다(수신하더라도 폐기). 클라이언트는 CI/DI 원문을 받지 않습니다.
